##############################################################################
# HIS Registry of Geography (ROG)
#
# Production reference data — no bridge exists; this file is the canonical
# source for ROG in GraphDB.
#
# Geography classification with 3-level hierarchy:
#   Region (5) → Subregion (22) → Country (242)
#
# Source:  gc-core/reference/data/peoplegroups.org/people_groups.csv
#          (IMB Comprehensive People Group List)
#
# Named graph: <https://data.global.church/his-registries/>
# URI pattern:
#   Scheme:    his:rog
#   Region:    rog:region-{slug}
#   Subregion: rog:subregion-{slug}
#   Country:   rog:{ROG-code}
#
# Version:    0.1.0
# Date:       2026-02-17
##############################################################################

@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix his:     <https://data.global.church/his/> .
@prefix rog:     <https://data.global.church/his/rog/> .


##############################################################################
#  CONCEPT SCHEME
##############################################################################

his:rog a skos:ConceptScheme ;
  skos:prefLabel "HIS Registry of Geography"@en ;
  dcterms:publisher "HIS Registries (hisregistries.org)" ;
  dcterms:description "Geography classification used across the missions data ecosystem. Three-level hierarchy: Region (5) → Subregion (22) → Country (242). Country codes are HIS ROG codes (2-letter), cross-referenced to ISO 3166-1 alpha-3."@en ;
  skos:hasTopConcept rog:region-africa ,
                     rog:region-americas ,
                     rog:region-asia ,
                     rog:region-europe ,
                     rog:region-oceania .


##############################################################################
#  REGIONS (5 top-level concepts)
##############################################################################

rog:region-africa a skos:Concept ;
  skos:inScheme his:rog ;
  skos:prefLabel "Africa"@en ;
  skos:topConceptOf his:rog ;
  skos:notation "Africa" ;
  skos:narrower rog:subregion-eastern-africa ,
                rog:subregion-middle-africa ,
                rog:subregion-northern-africa ,
                rog:subregion-southern-africa ,
                rog:subregion-western-africa .

rog:region-americas a skos:Concept ;
  skos:inScheme his:rog ;
  skos:prefLabel "Americas"@en ;
  skos:topConceptOf his:rog ;
  skos:notation "Americas" ;
  skos:narrower rog:subregion-caribbean ,
                rog:subregion-central-america ,
                rog:subregion-northern-america ,
                rog:subregion-south-america .

rog:region-asia a skos:Concept ;
  skos:inScheme his:rog ;
  skos:prefLabel "Asia"@en ;
  skos:topConceptOf his:rog ;
  skos:notation "Asia" ;
  skos:narrower rog:subregion-central-asia ,
                rog:subregion-eastern-asia ,
                rog:subregion-south-eastern-asia ,
                rog:subregion-southern-asia ,
                rog:subregion-western-asia .

rog:region-europe a skos:Concept ;
  skos:inScheme his:rog ;
  skos:prefLabel "Europe"@en ;
  skos:topConceptOf his:rog ;
  skos:notation "Europe" ;
  skos:narrower rog:subregion-eastern-europe ,
                rog:subregion-northern-europe ,
                rog:subregion-southern-europe ,
                rog:subregion-western-europe .

rog:region-oceania a skos:Concept ;
  skos:inScheme his:rog ;
  skos:prefLabel "Oceania"@en ;
  skos:topConceptOf his:rog ;
  skos:notation "Oceania" ;
  skos:narrower rog:subregion-australia-and-new-zealand ,
                rog:subregion-melanesia ,
                rog:subregion-micronesia ,
                rog:subregion-polynesia .

