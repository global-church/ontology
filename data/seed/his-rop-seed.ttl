##############################################################################
# HIS Registry of Peoples (ROP) — Seed Data
#
# Representative subset of the ROP hierarchy for local testing.
# Contains 3 Affinity Blocs, 4 People Clusters, 4 Kinship Groups,
# and 6 ROP3 Peoples matching the Denver test data diaspora groups
# plus 2 additional to demonstrate hierarchy traversal.
#
# Named graph: <https://data.global.church/his-registries/>
# Full dataset loaded by gc-his-bridge (Phase 2) from IMB ArcGIS.
#
# Version:    0.1.0 (seed data)
# Date:       2026-02-15
##############################################################################

@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix his:     <https://data.global.church/his/> .
@prefix rop1:    <https://data.global.church/his/rop1/> .
@prefix rop2:    <https://data.global.church/his/rop2/> .
@prefix rop25:   <https://data.global.church/his/rop25/> .
@prefix rop3:    <https://data.global.church/his/rop3/> .


##############################################################################
#  CONCEPT SCHEME
##############################################################################

his:rop a skos:ConceptScheme ;
  skos:prefLabel "HIS Registry of Peoples"@en ;
  dcterms:publisher "HIS Registries (hisregistries.org)" ;
  dcterms:description "Four-level classification of the world's peoples: Affinity Bloc → People Cluster → Kinship Group → People."@en ;
  skos:hasTopConcept rop1:6 ,
                     rop1:12 ,
                     rop1:13 .


##############################################################################
#  ROP1 — AFFINITY BLOCS
##############################################################################

rop1:6 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Horn of Africa Peoples"@en ;
  skos:topConceptOf his:rop ;
  skos:notation "6" ;
  skos:narrower rop2:307 ,
                rop2:101 .

rop1:12 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "South Asian Peoples"@en ;
  skos:topConceptOf his:rop ;
  skos:notation "12" ;
  skos:narrower rop2:254 .

rop1:13 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Southeast Asian Peoples"@en ;
  skos:topConceptOf his:rop ;
  skos:notation "13" ;
  skos:narrower rop2:132 .


##############################################################################
#  ROP2 — PEOPLE CLUSTERS
##############################################################################

rop2:307 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Somali"@en ;
  skos:broader rop1:6 ;
  skos:notation "307" ;
  skos:narrower rop25:307000 .

rop2:101 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Amhara-Tigrinya"@en ;
  skos:broader rop1:6 ;
  skos:notation "101" ;
  skos:narrower rop25:101000 .

rop2:254 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Nepali / Pahari"@en ;
  skos:broader rop1:12 ;
  skos:notation "254" ;
  skos:narrower rop25:254000 .

rop2:132 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Burmese"@en ;
  skos:broader rop1:13 ;
  skos:notation "132" ;
  skos:narrower rop25:132000 .


##############################################################################
#  ROP2.5 — KINSHIP GROUPS
##############################################################################

rop25:307000 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Somali"@en ;
  skos:broader rop2:307 ;
  skos:notation "307000" ;
  skos:narrower rop3:109392 .

rop25:101000 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Amhara"@en ;
  skos:broader rop2:101 ;
  skos:notation "101000" ;
  skos:narrower rop3:100293 ,
                rop3:115819 .

rop25:254000 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Nepali"@en ;
  skos:broader rop2:254 ;
  skos:notation "254000" ;
  skos:narrower rop3:107204 ,
                rop3:115261 .

rop25:132000 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Burmese"@en ;
  skos:broader rop2:132 ;
  skos:notation "132000" ;
  skos:narrower rop3:101776 .


##############################################################################
#  ROP3 — PEOPLES
#
#  4 matching Denver seed data + 2 additional for hierarchy demo
##############################################################################

# Denver match: Somali in USA (pg-somali-us)
rop3:109392 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Somali"@en ;
  skos:broader rop25:307000 ;
  skos:notation "109392" .

# Denver match: Amhara in USA (pg-amhara-us)
rop3:100293 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Amhara, Ethiopian"@en ;
  skos:broader rop25:101000 ;
  skos:notation "100293" .

# Additional: Tigrinya (same Kinship Group as Amhara — shows hierarchy)
rop3:115819 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Tigrinya"@en ;
  skos:broader rop25:101000 ;
  skos:notation "115819" .

# Denver match: Nepali in USA (pg-nepali-us)
rop3:107204 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Nepali"@en ;
  skos:broader rop25:254000 ;
  skos:notation "107204" .

# Additional: Tharu, Rana (same Kinship Group as Nepali — shows hierarchy)
rop3:115261 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Tharu, Rana"@en ;
  skos:broader rop25:254000 ;
  skos:notation "115261" .

# Denver match: Burmese in USA (pg-burmese-us)
rop3:101776 a skos:Concept ;
  skos:inScheme his:rop ;
  skos:prefLabel "Burmese"@en ;
  skos:broader rop25:132000 ;
  skos:notation "101776" .


##############################################################################
#  End of HIS ROP Seed Data
##############################################################################
