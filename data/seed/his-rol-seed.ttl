@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix his:     <https://data.global.church/his/> .
@prefix rol:     <https://data.global.church/his/rol/> .


##############################################################################
#  CONCEPT SCHEME
##############################################################################

his:rol a skos:ConceptScheme ;
  skos:prefLabel "HIS Registry of Languages"@en ;
  dcterms:publisher "HIS Registries (hisregistries.org)" ;
  dcterms:description "Classification of the world's languages by ISO 639-3 code. Flat scheme — each language is a direct member of the scheme."@en ;
  skos:hasTopConcept rol:eng ,
                     rol:spa ,
                     rol:som ,
                     rol:amh ,
                     rol:mya ,
                     rol:nep .


##############################################################################
#  LANGUAGE CONCEPTS
#
#  Each concept carries:
#    skos:notation     — ISO 639-3 code (the raw identifier)
#    skos:prefLabel    — English name of the language
#    skos:inScheme     — link to the ROL concept scheme
#    skos:topConceptOf — top-level (ROL is flat, no hierarchy)
##############################################################################

# Denver match: English
rol:eng a skos:Concept ;
  skos:inScheme his:rol ;
  skos:prefLabel "English"@en ;
  skos:topConceptOf his:rol ;
  skos:notation "eng" .

# Denver match: Spanish
rol:spa a skos:Concept ;
  skos:inScheme his:rol ;
  skos:prefLabel "Spanish"@en ;
