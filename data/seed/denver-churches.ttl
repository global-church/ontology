##############################################################################
#  RESOURCES — Orthogonal classification (domain × format × function)
#
#  Demonstrates the flat MissionResource model with three orthogonal
#  classification dimensions: content domain, delivery format, and
#  pedagogical function.  Also demonstrates multi-domain resources,
#  format separation (same content in multiple formats), in-progress
#  resources with completion tracking, provider attribution, accelerator
#  linkage, and collections.
#  Somali intentionally has NO scripture resources (gap case).
##############################################################################

# --- Scripture-domain Resources ---

# Burmese New Testament — text, available (from Wycliffe)
:resource-burmese-nt a gc:MissionResource ;
  gc:resourceName "Burmese New Testament" ;
  gc:resourceForPeopleGroup :pg-burmese-us ;
  gc:resourceDomain gc:DomainScriptureNT ;
  gc:resourceFunction gc:FunctionReferenceText ;
  gc:resourceFormat gc:FormatText ;
  gc:resourceStatus gc:ResourceAvailable ;
  gc:resourceProvider :org-wycliffe ;
  gc:resourceLanguage rol:mya ;
  gc:resourceDatePublished "2012-03-15"^^xsd:date ;
  gc:relatedAccelerator jp:AccScripture .

# Burmese New Testament — audio, in progress at 40% (from SIL)
# Same content domain (NT) as above, different format (audio) — demonstrates format separation
:resource-burmese-audio-nt a gc:MissionResource ;
  gc:resourceName "Burmese Audio New Testament" ;
  gc:resourceForPeopleGroup :pg-burmese-us ;
  gc:resourceDomain gc:DomainScriptureNT ;
  gc:resourceFunction gc:FunctionReferenceText ;
  gc:resourceFormat gc:FormatAudio ;
  gc:resourceStatus gc:ResourceInProgress ;
  gc:completionPercentage "0.40"^^xsd:decimal ;
  gc:estimatedCompletionDate "2027-06-01"^^xsd:date ;
  gc:resourceProvider :org-sil ;
  gc:resourceLanguage rol:mya ;
  gc:relatedAccelerator jp:AccAudioResources .

# Nepali Scripture Portions — text, available
:resource-nepali-portions a gc:MissionResource ;
  gc:resourceName "Nepali Scripture Portions" ;
  gc:resourceForPeopleGroup :pg-nepali-us ;
  gc:resourceDomain gc:DomainScripturePortions ;
  gc:resourceFunction gc:FunctionReferenceText ;
  gc:resourceFormat gc:FormatText ;
  gc:resourceStatus gc:ResourceAvailable ;
  gc:resourceLanguage rol:nep ;
  gc:relatedAccelerator jp:AccScripture .

# Somali — no scripture resources (gap case, demonstrated by absence)

# --- Evangelism-domain Resources ---

# JESUS Film for Amhara — evangelistic video, available
# Multi-domain: both Evangelism (primary purpose) and Scripture (content derived from Gospel of Luke)
:resource-amhara-film a gc:MissionResource ;
  gc:resourceName "JESUS Film - Amharic" ;
  gc:resourceForPeopleGroup :pg-amhara-us ;
  gc:resourceDomain gc:DomainEvangelism, gc:DomainScripture ;
  gc:resourceFunction gc:FunctionBroadcast ;
  gc:resourceFormat gc:FormatVideo ;
  gc:resourceStatus gc:ResourceAvailable ;
  gc:resourceLanguage rol:amh ;
  gc:relatedAccelerator jp:AccFilm .

# --- Leadership & Training-domain Resources ---

# Church planting curriculum for Somali — print, available (from Frontiers)
:resource-somali-curriculum a gc:MissionResource ;
  gc:resourceName "Somali Church Planting Curriculum" ;
  gc:resourceForPeopleGroup :pg-somali-us ;
  gc:resourceDomain gc:DomainChurchPlanting ;
  gc:resourceFunction gc:FunctionCurriculum ;
  gc:resourceFormat gc:FormatPrint ;
  gc:resourceStatus gc:ResourceAvailable ;
  gc:resourceProvider :org-frontiers ;
  gc:resourceLanguage rol:som ;
  gc:relatedAccelerator jp:AccChurchPlanting ;
  gc:resourceUrl "https://example.org/somali-cp-curriculum"^^xsd:anyURI .

# Nepali discipleship manual — in progress (from Cru), part of a collection
:resource-nepali-discipleship a gc:MissionResource ;
  gc:resourceName "Nepali Discipleship Manual" ;
  gc:resourceForPeopleGroup :pg-nepali-us ;
  gc:resourceDomain gc:DomainDiscipleship ;
  gc:resourceFunction gc:FunctionManual ;
  gc:resourceFormat gc:FormatPrint ;
  gc:resourceStatus gc:ResourceInProgress ;
  gc:resourceProvider :org-cru ;
  gc:resourceLanguage rol:nep ;
  gc:relatedAccelerator jp:AccLeaderDevelopment ;
  gc:partOfCollection :collection-nepali-discipleship .

# --- Evangelism Tool Resources ---

# GodTools for Amhara — conversation guide app, available (from Cru)
# Multi-domain: Evangelism (primary purpose) + Conversation Guide (specific evangelism sub-domain)
:resource-amhara-godtools a gc:MissionResource ;
  gc:resourceName "GodTools - Amharic" ;
  gc:resourceForPeopleGroup :pg-amhara-us ;
  gc:resourceDomain gc:DomainEvangelism, gc:DomainConversationGuide ;
  gc:resourceFunction gc:FunctionTool ;
  gc:resourceFormat gc:FormatApp ;
  gc:resourceStatus gc:ResourceAvailable ;
  gc:resourceProvider :org-cru ;
  gc:resourceLanguage rol:amh ;
  gc:relatedAccelerator jp:AccGospelPresentation .

# --- Resource Collections ---

# Nepali discipleship series (groups individual lessons)
:collection-nepali-discipleship a gc:ResourceCollection ;
  gc:collectionName "Nepali Discipleship Series" .


