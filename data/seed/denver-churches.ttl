##############################################################################
#  ORGANIZATIONS & SOFTWARE AGENTS
##############################################################################

:org-searchparty a gc:Organization ;
  gc:hasOrganizationType gc:OrgTypeMissionAgency ;
  rdfs:label "Search Party"@en ;
  rdfs:comment "501(c)(3) Colorado non-profit focused on starting discipleship and church planting movements among unreached people groups."@en .

:org-denver-missions-network a gc:Organization ;
  gc:hasOrganizationType gc:OrgTypeNetwork ;
  rdfs:label "Denver Missions Network"@en .

:ds-missiontool a gc:DataSource ;
  rdfs:label "MissionToolX"@en ;
  rdfs:comment "A mobile activity tracker used by Denver-area field workers."@en .

:ds-joshuaproject a gc:DataSource ;
  rdfs:label "Joshua Project"@en ;
  rdfs:comment "joshuaproject.net — people group data and 3D Insight."@en .

:bridge-gcdata a gc:GCBridge ;
  rdfs:label "GCData Bridge — Denver Node"@en .


##############################################################################
#  PERSONS
##############################################################################

:person-fw-a a gc:Person ;
  rdfs:label "Field Worker A"@en ;
  gc:userId "denver-fw-001" ;
  gc:personName "Field Worker A" ;
  gc:memberOf :org-searchparty ;
  gc:sendingOrganization :org-searchparty ;
  gc:deploymentStatus gc:DeploymentActive ;
  gc:isCrossCultural true ;
  gc:fieldEntryDate "2022-06-01"^^xsd:date .

:person-leader-b a gc:Person ;
  rdfs:label "Team Leader B"@en ;
  gc:userId "denver-fw-002" ;
  gc:personName "Team Leader B" ;
  gc:memberOf :org-searchparty ;
  gc:sendingOrganization :org-searchparty ;
  gc:deploymentStatus gc:DeploymentActive ;
  gc:isCrossCultural true ;
  gc:fieldEntryDate "2020-01-15"^^xsd:date .

:person-contact-c a gc:Person ;
  rdfs:label "Community Contact C"@en ;
  gc:userId "denver-contact-003" ;
  gc:personName "Community Contact C" .

:person-recorder-d a gc:Person ;
  rdfs:label "Data Recorder D"@en ;
  gc:userId "denver-rec-004" ;
  gc:personName "Data Recorder D" ;
  gc:memberOf :org-denver-missions-network ;
  gc:deploymentStatus gc:DeploymentActive ;
  gc:isCrossCultural false .


##############################################################################
#  CHURCHES (Denver area — real churches, modeled data)
##############################################################################

:church-calvary a gc:Organization ;
  gc:hasOrganizationType gc:OrgTypeChurch ;
  rdfs:label "Calvary Church — Centennial, CO"@en ;
  gc:isActive true ;
  gc:dateStarted "1951-06-15"^^xsd:date ;
  gc:identifiesAsChurch true ;
  gc:hasAppointedLeaders true ;
  gc:numberOfPeopleAttending "2500"^^xsd:nonNegativeInteger ;
  gc:numberOfBelievers "2100"^^xsd:nonNegativeInteger ;
  gc:numberOfBaptizedBelievers "1800"^^xsd:nonNegativeInteger ;
  gc:languageUsedWhenGathering "eng" ;
  gc:website "https://www.calvarychurch.com"^^xsd:anyURI ;
  gc:summary "A multi-generational, Bible-centered church in Centennial, Colorado serving the south Denver metro area since 1951." ;
  gc:hasBeliefClassification gc:BeliefChristian ;
  gc:hasDenominationClassification gc:DenomNonDenominational ;
  gc:servicesInfo "Sundays 9:00am & 11:00am" ;
  gc:isMultiCampus false ;
  gc:hasLocation :loc-calvary ;
  prov:wasGeneratedBy :act-calvary-formation ;
  prov:wasAttributedTo :person-leader-b ;
  gc:hasPractice :practice-calvary-baptism, :practice-calvary-lords-supper,
                   :practice-calvary-worship, :practice-calvary-teaching,
                   :practice-calvary-giving, :practice-calvary-disciplemaking ;
  gc:hasPeopleGroupEngagement :pge-calvary-anglo, :pge-calvary-hispanic ;
  gc:servesPeopleGroup :pg-angloamerican, :pg-hispanic-us .

:church-arise a gc:Organization ;
