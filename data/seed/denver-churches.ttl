##############################################################################
#  OVERTURE MAPS PLACE RECORDS
#
#  Simulated Overture Maps "places" theme records for Denver churches.
#  In production, these would be imported from Overture GeoParquet data.
##############################################################################

:overture-calvary a gc:Overture ;
  rdfs:label "Overture: Calvary Church"@en ;
  gc:overtureId "08f2e5881235e5d5041716bcbbfceeed" ;
  gc:overtureCategory "place_of_worship" ;
  gc:overtureConfidence "0.92"^^xsd:double ;
  gc:overtureSourceDataset "meta" ;
  gc:matchedOrganization :church-calvary ;
  gc:overtureLocation :loc-calvary ;
  gc:targetsPeopleGroup :pg-angloamerican ;
