##############################################################################
# GC-Core Ontology — Test Data: Denver, Colorado
#
# Real-world instance data for Denver-area churches, people groups,
# ministry activities, Overture Maps records, and engagement assessments.
# Exercises all major ontology classes and provenance patterns.
#
# Version:    0.15.1 (test data — Organization Supabase fields + BeliefType/Denomination)
# Date:       2026-02-25
##############################################################################

@base          <https://data.global.church/denver/> .
@prefix :      <https://data.global.church/denver/> .
@prefix gc:    <https://ontology.global.church/core#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix jp:    <https://ontology.global.church/joshuaproject#> .
@prefix rop3:  <https://data.global.church/his/rop3/> .
@prefix rol:   <https://data.global.church/his/rol/> .
@prefix ror:   <https://data.global.church/his/ror/> .


##############################################################################
#  LOCATIONS
##############################################################################

:loc-denver a gc:Location ;
