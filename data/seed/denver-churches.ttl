##############################################################################
#  LANGUAGES — now ROL SKOS concepts in his-rol-seed.ttl
#  (gc:Language class removed in v0.5.0 — languages are reference data
#   owned by HIS ROL / ISO 639-3, modeled as SKOS ConceptScheme)
#
#  URIs: <https://data.global.church/his/rol/{iso639-3-code}>
#  Named graph: <https://data.global.church/his-registries/>
##############################################################################


##############################################################################
#  RELIGIONS — now ROR SKOS concepts in <https://data.global.church/his-registries/>
#  See data/seed/his-ror-seed.ttl. Use gc:hasReligionClassification to link.
##############################################################################


##############################################################################
#  PEOPLE GROUPS (Denver-area diaspora + local)
##############################################################################

