##############################################################################
# Claim Status Vocabulary — SKOS Concept Scheme
#
# Status values for gc:EngagementClaim: Active, Paused, Completed,
# Withdrawn. Follows the same pattern as gc:EndorsementStatusScheme.
#
# Used via gc:claimStatus on gc:EngagementClaim.
#
# This is a gc:-owned vocabulary — Global.Church is the authority on
# engagement claim status values.
#
# Named graph: loaded alongside ontology (default graph or seed graph)
# Namespace:   https://ontology.global.church/core#
#
# Version:    0.1.0
# Date:       2026-02-26
##############################################################################

@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix gc:      <https://ontology.global.church/core#> .


##############################################################################
#  Claim Status Scheme
#
#  Flat vocabulary (no hierarchy). Each concept is a top concept.
#  Lifecycle: Active → Paused → Active (resume) → Completed
#             Active → Withdrawn (at any point)
##############################################################################

gc:ClaimStatusScheme a skos:ConceptScheme ;
  skos:prefLabel "Claim Status"@en ;
  dcterms:publisher "Global Church Alliance" ;
  dcterms:description "Status values for self-reported engagement claims. Tracks whether the claimed engagement is currently active, temporarily paused, completed, or withdrawn."@en ;
  dcterms:created "2026-02-26"^^xsd:date ;
  skos:hasTopConcept gc:ClaimStatusActive ,
                     gc:ClaimStatusPaused ,
                     gc:ClaimStatusCompleted ,
                     gc:ClaimStatusWithdrawn .

gc:ClaimStatusActive a skos:Concept ;
  skos:inScheme gc:ClaimStatusScheme ;
  skos:topConceptOf gc:ClaimStatusScheme ;
  skos:prefLabel "Active"@en ;
  skos:notation "ACT" ;
  skos:definition "The engagement is currently active — the organization is doing this work."@en .

gc:ClaimStatusPaused a skos:Concept ;
  skos:inScheme gc:ClaimStatusScheme ;
  skos:topConceptOf gc:ClaimStatusScheme ;
  skos:prefLabel "Paused"@en ;
  skos:notation "PAU" ;
  skos:definition "The engagement is temporarily paused but the organization intends to resume."@en .

gc:ClaimStatusCompleted a skos:Concept ;
  skos:inScheme gc:ClaimStatusScheme ;
  skos:topConceptOf gc:ClaimStatusScheme ;
  skos:prefLabel "Completed"@en ;
  skos:notation "CMP" ;
  skos:definition "The engagement work has been completed."@en .

gc:ClaimStatusWithdrawn a skos:Concept ;
  skos:inScheme gc:ClaimStatusScheme ;
  skos:topConceptOf gc:ClaimStatusScheme ;
  skos:prefLabel "Withdrawn"@en ;
  skos:notation "WDN" ;
  skos:definition "The engagement claim has been withdrawn by the organization."@en .
