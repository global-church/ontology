##############################################################################
# Denomination Vocabulary — SKOS Concept Scheme
#
# Classifies organizations by denomination: Baptist, Methodist,
# Presbyterian, Lutheran, Pentecostal, Anglican, NonDenominational, Other.
#
# Used via gc:hasDenominationClassification on gc:Organization.
#
# This is a gc:-owned vocabulary — Global.Church is the authority on what
# denomination classifications exist in its coordination platform.
#
# Named graph: loaded alongside ontology (default graph or seed graph)
# Namespace:   https://ontology.global.church/core#
#
# Version:    0.1.0
# Date:       2026-02-25
##############################################################################

@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix gc:      <https://ontology.global.church/core#> .


##############################################################################
#  Denomination Scheme
#
#  Flat vocabulary (no hierarchy). Each concept is a top concept.
#  Extensible — new denominations can be added without ontology changes.
##############################################################################

gc:DenominationScheme a skos:ConceptScheme ;
  skos:prefLabel "Denomination"@en ;
  dcterms:publisher "Global Church Alliance" ;
  dcterms:description "Classification of organizations by denomination. Used to identify the denominational affiliation of churches and related organizations."@en ;
  dcterms:created "2026-02-25"^^xsd:date ;
  skos:hasTopConcept gc:DenomBaptist ,
                     gc:DenomMethodist ,
                     gc:DenomPresbyterian ,
                     gc:DenomLutheran ,
                     gc:DenomPentecostal ,
                     gc:DenomAnglican ,
                     gc:DenomNonDenominational ,
                     gc:DenomOther .

gc:DenomBaptist a skos:Concept ;
  skos:inScheme gc:DenominationScheme ;
  skos:topConceptOf gc:DenominationScheme ;
  skos:prefLabel "Baptist"@en ;
  skos:notation "BAP" ;
  skos:definition "Baptist denomination — includes Southern Baptist, American Baptist, Independent Baptist, and other Baptist traditions."@en .

gc:DenomMethodist a skos:Concept ;
  skos:inScheme gc:DenominationScheme ;
  skos:topConceptOf gc:DenominationScheme ;
  skos:prefLabel "Methodist"@en ;
  skos:notation "MET" ;
  skos:definition "Methodist denomination — includes United Methodist, Free Methodist, Wesleyan, and other Methodist traditions."@en .

gc:DenomPresbyterian a skos:Concept ;
  skos:inScheme gc:DenominationScheme ;
  skos:topConceptOf gc:DenominationScheme ;
  skos:prefLabel "Presbyterian"@en ;
  skos:notation "PRE" ;
  skos:definition "Presbyterian denomination — includes PCA, PCUSA, EPC, and other Presbyterian/Reformed traditions."@en .

gc:DenomLutheran a skos:Concept ;
  skos:inScheme gc:DenominationScheme ;
  skos:topConceptOf gc:DenominationScheme ;
  skos:prefLabel "Lutheran"@en ;
  skos:notation "LUT" ;
  skos:definition "Lutheran denomination — includes ELCA, LCMS, WELS, and other Lutheran traditions."@en .

gc:DenomPentecostal a skos:Concept ;
  skos:inScheme gc:DenominationScheme ;
  skos:topConceptOf gc:DenominationScheme ;
  skos:prefLabel "Pentecostal"@en ;
  skos:notation "PEN" ;
  skos:definition "Pentecostal denomination — includes Assemblies of God, Church of God, Foursquare, and other Pentecostal/Charismatic traditions."@en .

gc:DenomAnglican a skos:Concept ;
  skos:inScheme gc:DenominationScheme ;
  skos:topConceptOf gc:DenominationScheme ;
  skos:prefLabel "Anglican"@en ;
  skos:notation "ANG" ;
  skos:definition "Anglican denomination — includes Episcopal, ACNA, Church of England, and other Anglican Communion traditions."@en .

gc:DenomNonDenominational a skos:Concept ;
  skos:inScheme gc:DenominationScheme ;
  skos:topConceptOf gc:DenominationScheme ;
  skos:prefLabel "Non-Denominational"@en ;
  skos:notation "NON" ;
  skos:definition "Non-denominational — independent churches not affiliated with a formal denomination."@en .

gc:DenomOther a skos:Concept ;
  skos:inScheme gc:DenominationScheme ;
  skos:topConceptOf gc:DenominationScheme ;
  skos:prefLabel "Other"@en ;
  skos:notation "OTH" ;
  skos:definition "Other denomination not covered by the above categories."@en .
