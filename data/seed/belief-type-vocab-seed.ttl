##############################################################################
# Belief Type Vocabulary — SKOS Concept Scheme
#
# Classifies organizations by belief tradition: Christian, Catholic,
# Orthodox, LDS, JW, Other.
#
# Used via gc:hasBeliefClassification on gc:Organization.
#
# This is a gc:-owned vocabulary — Global.Church is the authority on what
# belief type classifications exist in its coordination platform.
#
# Named graph: loaded alongside ontology (default graph or seed graph)
# Namespace:   https://ontology.global.church/core#
#
# Version:    0.1.0
# Date:       2026-02-25
##############################################################################

@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix gc:      <https://ontology.global.church/core#> .


##############################################################################
#  Belief Type Scheme
#
#  Flat vocabulary (no hierarchy). Each concept is a top concept.
#  Extensible — new belief types can be added without ontology changes.
##############################################################################

gc:BeliefTypeScheme a skos:ConceptScheme ;
  skos:prefLabel "Belief Type"@en ;
  dcterms:publisher "Global Church Alliance" ;
  dcterms:description "Classification of organizations by belief tradition. Used to distinguish Christian denominations and traditions from other groups that may appear in church directories (LDS, JW, etc.)."@en ;
  dcterms:created "2026-02-25"^^xsd:date ;
  skos:hasTopConcept gc:BeliefChristian ,
                     gc:BeliefCatholic ,
                     gc:BeliefOrthodox ,
                     gc:BeliefLDS ,
                     gc:BeliefJW ,
                     gc:BeliefOther .

gc:BeliefChristian a skos:Concept ;
  skos:inScheme gc:BeliefTypeScheme ;
  skos:topConceptOf gc:BeliefTypeScheme ;
  skos:prefLabel "Christian"@en ;
  skos:notation "CHR" ;
  skos:definition "Protestant/Evangelical Christian tradition — the default classification for churches that do not fall into a more specific category."@en .

gc:BeliefCatholic a skos:Concept ;
  skos:inScheme gc:BeliefTypeScheme ;
  skos:topConceptOf gc:BeliefTypeScheme ;
  skos:prefLabel "Catholic"@en ;
  skos:notation "CAT" ;
  skos:definition "Roman Catholic tradition."@en .

gc:BeliefOrthodox a skos:Concept ;
  skos:inScheme gc:BeliefTypeScheme ;
  skos:topConceptOf gc:BeliefTypeScheme ;
  skos:prefLabel "Orthodox"@en ;
  skos:notation "ORT" ;
  skos:definition "Eastern Orthodox, Oriental Orthodox, or other Orthodox tradition."@en .

gc:BeliefLDS a skos:Concept ;
  skos:inScheme gc:BeliefTypeScheme ;
  skos:topConceptOf gc:BeliefTypeScheme ;
  skos:prefLabel "LDS"@en ;
  skos:notation "LDS" ;
  skos:definition "The Church of Jesus Christ of Latter-day Saints (Mormon)."@en .

gc:BeliefJW a skos:Concept ;
  skos:inScheme gc:BeliefTypeScheme ;
  skos:topConceptOf gc:BeliefTypeScheme ;
  skos:prefLabel "Jehovah's Witnesses"@en ;
  skos:notation "JW" ;
  skos:definition "Jehovah's Witnesses (Watch Tower Society)."@en .

gc:BeliefOther a skos:Concept ;
  skos:inScheme gc:BeliefTypeScheme ;
  skos:topConceptOf gc:BeliefTypeScheme ;
  skos:prefLabel "Other"@en ;
  skos:notation "OTH" ;
  skos:definition "Other belief tradition not covered by the above categories."@en .
